# Vance local configuration.
VANCE_MODE=fallback
VANCE_HOST=127.0.0.1
VANCE_PORT=8000
VANCE_TASK_DIR=tasks
VANCE_TRACE_DIR=evals/traces
VANCE_DEMO_TRACE_DIR=demo/sample_traces

# Required only for --mode live --agent fireworks_agent.
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/qwen2p5-7b-instruct
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# HUD setup. Optional until running HUD platform commands.
HUD_API_KEY=
HUD_ENV_ID=
HUD_PROJECT=vance-safeopsrl

# Optional sponsor/deployment integrations.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
DAYTONA_API_KEY=
EXA_API_KEY=
MINIMAX_API_KEY=
