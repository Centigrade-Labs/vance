# Vance local configuration.
# Fallback mode does not require any API keys.

VANCE_MODE=fallback
VANCE_HOST=127.0.0.1
VANCE_PORT=8000
VANCE_TASK_DIR=tasks
VANCE_TRACE_DIR=evals/traces
VANCE_DEMO_TRACE_DIR=demo/sample_traces

# Live SLM inference through Fireworks. Optional unless VANCE_MODE=live.
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# HUD setup. Optional until the HUD adapter is connected.
HUD_API_KEY=
HUD_ENV_ID=
HUD_PROJECT=vance-safeopsrl

# Optional sponsor/deployment integrations.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
DAYTONA_API_KEY=
EXA_API_KEY=
MINIMAX_API_KEY=

# GitHub publishing helpers. The gh CLI auth is used by default.
GITHUB_OWNER=
GITHUB_REPO=vance
